# ── OpenAI ─────────────────────────────────────────────────────────────────
# Required: used server-side in /api/extract_locations for AI address extraction.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# ── Google Maps (optional) ──────────────────────────────────────────────────
# Optional: enables fast batch geocoding. Falls back to Nominatim (OSM) if absent.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# ── Supabase ────────────────────────────────────────────────────────────────
# Required for persistent storage of processed tasks and cross-tab real-time sync.
# Get these from https://app.supabase.com → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Optional: only needed for elevated server-side operations (defaults to anon key).
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

